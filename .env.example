# Required
OPENROUTER_API_KEY=        # primary LLM gateway — openrouter.ai
NOMIC_API_KEY=             # embeddings — free tier at nomic.ai (1M tokens/month)
TELEGRAM_BOT_TOKEN=        # from BotFather — used for briefings, alerts, and query-back
TELEGRAM_CHAT_ID=          # your personal chat ID — send /start to @userinfobot to get it
DATABASE_URL=              # postgres+psycopg://user:pass@host:5432/db — injected by Railway in prod

# LangSmith tracing
LANGSMITH_TRACING=         # set to "true" to enable LangSmith tracing
LANGSMITH_API_KEY=         # from smith.langchain.com — required when tracing is enabled
LANGSMITH_PROJECT=         # LangSmith project name, e.g. "briefcast-dev"
LANGSMITH_ENDPOINT=        # https://apac.api.smith.langchain.com (APAC) or https://api.smith.langchain.com (US)

# Tuning
DEDUP_THRESHOLD=           # cosine similarity cutoff for near-duplicate detection; default 0.92
