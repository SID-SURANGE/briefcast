# Required
OPENROUTER_API_KEY=        # primary LLM gateway — openrouter.ai
NOMIC_API_KEY=             # embeddings — free tier at nomic.ai (1M tokens/month)
TELEGRAM_BOT_TOKEN=        # from BotFather — used for briefings, alerts, and query-back
TELEGRAM_CHAT_ID=          # your personal chat ID — send /start to @userinfobot to get it
# DATABASE_URL — Docker Compose overrides this automatically (no need to set for docker compose up)
# Manual local dev: postgresql+psycopg://briefcast:briefcast@localhost:5432/briefcast
# Railway: injected automatically — do not set here
DATABASE_URL=

# LangSmith tracing
LANGSMITH_TRACING=         # set to "true" to enable LangSmith tracing
LANGSMITH_API_KEY=         # from smith.langchain.com — required when tracing is enabled
LANGSMITH_PROJECT=         # LangSmith project name, e.g. "briefcast-dev"
LANGSMITH_ENDPOINT=        # https://apac.api.smith.langchain.com (APAC) or https://api.smith.langchain.com (US)

# OpenRouter app identity (shown in OpenRouter dashboard under Apps)
OPENROUTER_APP_REFERER=    # your GitHub repo URL, e.g. https://github.com/username/briefcast

# Web search fallback (Tavily — free tier: 1,000 searches/month)
# Get key at: https://app.tavily.com — used when corpus has no relevant articles
TAVILY_API_KEY=            # leave blank to disable web search fallback

# Telegram Forum Topics — optional (for supergroup with Topics enabled)
# Create a Supergroup → enable Topics → right-click each topic → Copy Link → extract thread ID from URL
# If unset, briefings and alerts post to the main chat (current default behaviour)
TELEGRAM_BRIEFING_THREAD_ID=   # integer thread ID for the 📰 Briefing topic
TELEGRAM_ALERT_THREAD_ID=      # integer thread ID for the ⚠️ Alerts topic

# Tuning
DEDUP_THRESHOLD=           # cosine similarity cutoff for near-duplicate detection; default 0.92
